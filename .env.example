# =====================================================
# ChronoIndex 環境変数設定ファイル
# このファイルを .env にコピーして実際の値を入力する
#   cp .env.example .env
# =====================================================

# -------------------------------------------------------
# LLM API キー
# -------------------------------------------------------
# OpenAI API キー（GPT-4o / Whisper API に使用）
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API キー（Claude Sonnet に使用）
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------
# HuggingFace トークン
# 話者ダイアライゼーション（pyannote.audio）に必要
# https://huggingface.co/settings/tokens
# 使用前に以下のモデルの利用規約に同意が必要:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
# -------------------------------------------------------
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------
# ASR 設定
# -------------------------------------------------------
# ASR モード: "api" (OpenAI Whisper API) | "local" (faster-whisper ローカル実行)
# GPU なし環境では "api" が推奨（処理速度が大幅に速い）
ASR_MODE=api

# ローカル Whisper モデルサイズ（ASR_MODE=local のときのみ有効）
# tiny / base / small / medium / large-v3
# GPU なし環境では "small" または "base" を推奨（large-v3 は非常に遅い）
WHISPER_MODEL_SIZE=small

# -------------------------------------------------------
# LLM 設定
# -------------------------------------------------------
# チャプタータイトル生成に使用する LLM プロバイダー
# "openai" | "anthropic"
LLM_PROVIDER=openai

# OpenAI モデル名（LLM_PROVIDER=openai のときに使用）
OPENAI_MODEL=gpt-4o-mini

# Anthropic モデル名（LLM_PROVIDER=anthropic のときに使用）
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# LLM の Temperature（低いほどハルシネーションが減る）
LLM_TEMPERATURE=0.1

# -------------------------------------------------------
# 処理設定
# -------------------------------------------------------
# 言語（Whisper の言語指定）
AUDIO_LANGUAGE=ja

# ウィンドウサイズ（長尺動画の分割処理、単位: 秒）
WINDOW_SIZE_SEC=3600

# 空白区間の最小長さ（これ以上の無音が続いたら BLANK 候補, 単位: 秒）
BLANK_MIN_SILENCE_SEC=30

# データ出力ディレクトリ
DATA_DIR=/app/data
